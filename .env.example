# Server Configuration
NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database

# JWT
JWT_SECRET=your_jwt_secret_key_here

# Razorpay
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Email Configuration (Nodemailer)
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Frontend URLs (for CORS and redirects)
CLIENT_URL=http://localhost:5173
FRONTEND_URL=https://hireviva.vercel.app

# AI Service (Groq)
GROQ_API_KEY=your_groq_api_key

# Refund Webhook (if using external refund service)
REFUND_WEBHOOK_URL=https://your-domain.com/api/refund

# Admin Email
ADMIN_EMAIL=admin@hireviva.com
